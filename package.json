{
  "name": "sample-x402-content-monetization-with-cloudfront-and-waf",
  "version": "0.1.0",
  "description": "One-click deployable AWS solution for x402 content monetization at the edge using Amazon CloudFront, AWS Lambda@Edge, and AWS WAF",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:editor": "cd editor && npm ci && npm run build",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:property": "jest --testPathPattern=tests/property",
    "test:integration": "jest --testPathPattern=tests/integration",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "x402",
    "aws",
    "cloudfront",
    "lambda-edge",
    "waf",
    "payment",
    "monetization"
  ],
  "license": "MIT-0",
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.985.0",
    "@aws-sdk/client-secrets-manager": "^3.985.0",
    "@aws-sdk/client-ssm": "^3.985.0",
    "@aws-sdk/client-wafv2": "^3.985.0",
    "@x402/core": "^2.3.0",
    "@x402/evm": "^2.3.0",
    "jose": "^6.1.3"
  },
  "devDependencies": {
    "@coinbase/cdp-sdk": "^1.44.1",
    "@types/aws-lambda": "^8.10.160",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.1",
    "@x402/fetch": "^2.3.0",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-jest": "^4.1.0",
    "dotenv": "^17.3.0",
    "esbuild": "^0.27.3",
    "fast-check": "^4.5.3",
    "jest": "^30.2.0",
    "js-yaml": "^4.1.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
